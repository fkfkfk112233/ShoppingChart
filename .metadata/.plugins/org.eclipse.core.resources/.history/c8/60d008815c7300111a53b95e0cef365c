package controller.user;

import java.awt.Cursor;
import java.awt.EventQueue;

import javax.swing.JFrame;
import javax.swing.JPanel;
import javax.swing.border.EmptyBorder;

import model.Users;
import model.Roles;
import service.impl.UserServiceImpl;

import javax.swing.JLabel;
import java.awt.Font;
import javax.swing.JTextField;
import java.awt.event.FocusAdapter;
import java.awt.event.FocusEvent;
import javax.swing.JButton;
import javax.swing.border.BevelBorder;
import java.awt.event.MouseAdapter;
import java.awt.event.MouseEvent;

public class LoginUi extends JFrame {

	private static final long serialVersionUID = 1L;
	private JPanel contentPane;
	private JTextField acc;
	private JTextField pwd;

	/**
	 * Launch the application.
	 */
	public static void main(String[] args) {
		EventQueue.invokeLater(new Runnable() {
			public void run() {
				try {
					LoginUi frame = new LoginUi();
					frame.setVisible(true);
				} catch (Exception e) {
					e.printStackTrace();
				}
			}
		});
	}

	/**
	 * Create the frame.
	 */
	public LoginUi() {
		setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);
		setBounds(100, 100, 350, 420);
		contentPane = new JPanel();
		contentPane.setBorder(new EmptyBorder(1, 1, 1, 1));
		setContentPane(contentPane);
		contentPane.setLayout(null);
		
		JLabel lblNewLabel = new JLabel("歡迎回來");
		lblNewLabel.setFont(new Font("新細明體", Font.BOLD, 20));
		lblNewLabel.setBounds(120, 10, 90, 50);
		contentPane.add(lblNewLabel);
		
		JLabel msg = new JLabel("");
		msg.setBounds(50, 250, 230, 80);
		contentPane.add(msg);
		
		/**********************event**********************/
		UserServiceImpl usi=new UserServiceImpl();
		
		acc = new JTextField("請輸入帳號");
		acc.addFocusListener(new FocusAdapter() {
			@Override
			public void focusGained(FocusEvent e) {
				if(acc.getText().equals("請輸入帳號"))
				{
					acc.setText("");
				}
			}
			@Override
			public void focusLost(FocusEvent e) {
		        if(acc.getText().isEmpty()) 
		        {
		            acc.setText("請輸入帳號");
		        }
			}
		});
		
		acc.setBounds(50, 70, 230, 30);
		contentPane.add(acc);
		acc.setColumns(10);
		
		pwd = new JTextField("請輸入密碼");
		pwd.addFocusListener(new FocusAdapter() {
			@Override
			public void focusGained(FocusEvent e) {
				if(pwd.getText().equals("請輸入密碼"))
				{
					pwd.setText("");
				}
			}
			@Override
			public void focusLost(FocusEvent e) {
				if(pwd.getText().isEmpty())
				{
					pwd.setText("請輸入密碼");
				}
			}
		});
		pwd.setColumns(10);
		pwd.setBounds(50, 125, 230, 30);
		contentPane.add(pwd);
		
		JButton login = new JButton("登入");
		login.addMouseListener(new MouseAdapter() {
			@Override
			public void mouseClicked(MouseEvent e) {
				String Account=acc.getText();
				String Password=pwd.getText();
				
				Users user=usi.login(Account, Password);
				
				if(user!=null)
				{

					if(user.getRoleId() == 1)
					{
						new ManagerUi().setVisible(true);
					}
					else
					{
						new UserUi().setVisible(true);
						
					}
					
					dispose();
					
				}
				else
				{
//					LoginFailed loginfailed=new LoginFailed();
//					loginfailed.setVisible(true);
//					dispose();
					
					msg.setText("沒有帳號?請先註冊");
				}
			}
		});
		login.setBounds(120, 190, 84, 22);
		contentPane.add(login);
		
		JLabel add = new JLabel("註冊");
		add.setCursor(
			    Cursor.getPredefinedCursor(Cursor.HAND_CURSOR)
			);
		add.addMouseListener(new MouseAdapter() {
			@Override
			public void mouseClicked(MouseEvent e) {
				AddUser adduser=new AddUser();
				adduser.setVisible(true);
				dispose();
			}
		});
		add.setBounds(150, 216, 30, 22);
		contentPane.add(add);
		


	}
}
