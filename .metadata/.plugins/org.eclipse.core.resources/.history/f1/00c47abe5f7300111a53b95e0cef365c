package dao;

import model.Cart;

public interface CartDao {

    // 新增購物車
    void insert(Cart chart);

    // 查詢全部
    String selectAll();

    // 依使用者查詢
    String selectByUserId(int userId);

    // 依商品查詢
    Cart selectByProductId(int productId);

    // 修改
    void update(Cart chart);

    // 刪除指定商品
    void delete(int productId);

    // 清空購物車
    void deleteByUserId(int userId);

}